{
  "name": "openpawl",
  "version": "0.3.0",
  "description": "Terminal AI coding with a team of agents, not just one.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codepawl/openpawl.git"
  },
  "homepage": "https://github.com/codepawl/openpawl",
  "keywords": [
    "ai",
    "coding",
    "agent",
    "multi-agent",
    "terminal",
    "tui",
    "llm",
    "orchestration",
    "team",
    "vibe-coding"
  ],
  "workspaces": [
    "src/web/client",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "openpawl": "dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CLAUDE.md"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "dev:cli": "tsx src/cli.ts",
    "dev:work": "tsx src/cli.ts work",
    "dev:web": "tsx src/cli.ts web",
    "build": "tsup && bun run --cwd src/web/client build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "bun test tests/e2e/",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "lint": "eslint src/",
    "web": "tsup && NODE_ENV=production node dist/cli.js web",
    "work": "tsup && node dist/cli.js work --web",
    "test:file": "bun test",
    "benchmark": "tsx scripts/testing/benchmark.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1012.0",
    "@clack/core": "^1.1.0",
    "@clack/prompts": "^0.9.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^8.3.0",
    "@instructor-ai/instructor": "^1.7.0",
    "@lancedb/lancedb": "^0.17.0",
    "@t3-oss/env-core": "^0.13.10",
    "better-sqlite3": "^12.8.0",
    "bootstrap-icons": "^1.13.1",
    "cli-highlight": "^2.1.11",
    "damerau-levenshtein": "^1.0.8",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "langfuse": "^3.38.6",
    "neverthrow": "^8.2.0",
    "open": "^11.0.0",
    "openai": "^6.32.0",
    "picocolors": "^1.1.1",
    "secure-exec": "^0.1.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.3",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "overrides": {
    "langsmith": ">=0.4.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/damerau-levenshtein": "^1.0.2",
    "@types/node": "^22.19.15",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "bun-types": "^1.3.11",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  },
  "bugs": {
    "url": "https://github.com/codepawl/openpawl/issues"
  }
}
