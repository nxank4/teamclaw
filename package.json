{
  "name": "teamclaw",
  "version": "1.0.0",
  "description": "Orchestrate AI agent teams with memory, learning, and structured collaboration",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nxank4/teamclaw.git"
  },
  "homepage": "https://github.com/nxank4/teamclaw",
  "keywords": [
    "ai",
    "agents",
    "cli",
    "llm",
    "team",
    "orchestration"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "teamclaw": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup && pnpm --dir src/web/client build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "web": "tsup && NODE_ENV=production node dist/cli.js web",
    "work": "tsup && node dist/cli.js work --web"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1012.0",
    "@clack/prompts": "^0.9.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^8.3.0",
    "@lancedb/lancedb": "^0.17.0",
    "@langchain/langgraph": "^0.2.74",
    "@langchain/langgraph-checkpoint": "^0.0.17",
    "bootstrap-icons": "^1.13.1",
    "damerau-levenshtein": "^1.0.8",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "open": "^11.0.0",
    "openai": "^6.32.0",
    "picocolors": "^1.1.1",
    "secure-exec": "^0.1.0",
    "ws": "^8.19.0",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "overrides": {
      "langsmith": ">=0.4.6"
    }
  },
  "devDependencies": {
    "@types/damerau-levenshtein": "^1.0.2",
    "@types/node": "^22.19.15",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "vitest": "^2.1.9"
  }
}
