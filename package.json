{
  "name": "teamclaw-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup && pnpm --dir src/web/client build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "web": "tsup && NODE_ENV=production node dist/cli.js web",
    "work": "tsup && node dist/cli.js work --web"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^8.3.0",
    "@lancedb/lancedb": "^0.17.0",
    "@langchain/langgraph": "^0.2.74",
    "@langchain/langgraph-checkpoint": "^0.0.17",
    "bootstrap-icons": "^1.13.1",
    "fastify": "^5.8.2",
    "picocolors": "^1.1.1",
    "ws": "^8.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "vitest": "^2.1.9"
  }
}
