{
  "name": "teamclaw",
  "version": "0.1.0",
  "description": "OpenClaw bot team orchestration. Define goals, assign work, and run company-like workflows with LangGraph and RAG.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "main": "./dist/index.js",
  "bin": {
    "teamclaw": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup && pnpm run client:build",
    "client:build": "cd src/web/client && pnpm run build",
    "client:dev": "cd src/web/client && pnpm run dev",
    "dev": "pnpm run build && concurrently -n tsup,web -c blue,green \"tsup --watch\" \"nodemon --watch dist --ext js --delay 500 --exec 'node dist/cli.js web'\"",
    "work": "node dist/cli.js work --web",
    "work:cli": "node dist/cli.js work",
    "web": "NODE_ENV=production node dist/cli.js web",
    "onboard": "node dist/onboard.js",
    "check": "node dist/cli.js check",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src && echo \"Lint OK\"",
    "typecheck": "tsc --noEmit && echo \"Typecheck OK\""
  },
  "keywords": [
    "ai-agents",
    "langgraph",
    "multi-agent",
    "rag",
    "team-orchestration"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^8.0.2",
    "@fastify/websocket": "^11.0.1",
    "@langchain/core": "^0.3.29",
    "@langchain/langgraph": "^0.2.20",
    "@langchain/langgraph-checkpoint": "^0.0.17",
    "chromadb": "^1.8.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "ink": "^5.0.1",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "ollama": "^0.5.0",
    "react": "^18.3.1",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "nodemon": "^3.1.14",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "langsmith": ">=0.4.6"
    }
  }
}
