# TeamClaw Configuration
# Copy to .env and modify as needed

# LLM (Ollama — when not using gateway)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
LLM_TEMPERATURE=0.7
CREATIVITY=0.5
# Optional: LLM request timeout (ms). Default 120000. Increase if Ollama is slow.
# LLM_TIMEOUT_MS=120000

# AI Gateway (LiteLLM) — when set, TeamClaw and OpenClaw use this instead of direct Ollama
# See llm-config.yaml for model_list. TEAM_MODEL must match a model_name there.
# GATEWAY_URL=http://localhost:4000
# TEAM_MODEL=team-default
# LITELLM_CONFIG_PATH=./llm-config.yaml

# Work session limits
MAX_CYCLES=10
MAX_RUNS=5

# OpenClaw Workers
# Single worker (all bots use this URL)
# When using Docker with --profile openclaw, use: OPENCLAW_WORKER_URL=http://openclaw:3000
OPENCLAW_WORKER_URL=http://localhost:8001

# Optional: per-bot URLs (JSON)
# OPENCLAW_WORKERS='{"bot_0":"http://localhost:8001","bot_1":"http://localhost:8002"}'

# Optional: auth token for OpenClaw workers
# OPENCLAW_AUTH_TOKEN=your-token

# Optional: provisioning handshake timeout (ms)
# OPENCLAW_PROVISION_TIMEOUT=30000

# Vector Memory (ChromaDB) — optional; falls back to JSON if unavailable
CHROMADB_PERSIST_DIR=data/vector_store
# When running Chroma locally, default port is 8020 to avoid clash with web server (8000)
# CHROMADB_PORT=8020
# With Docker: CHROMADB_HOST=chromadb and CHROMADB_PORT=8000

# Webhooks (Discord, Slack, Telegram — see docs/WEBHOOKS.md)
# WEBHOOK_ON_TASK_COMPLETE=https://discord.com/api/webhooks/...
# WEBHOOK_ON_CYCLE_END=https://hooks.slack.com/...
# WEBHOOK_SECRET=optional-signature-secret

# Logging
VERBOSE_LOGGING=true
