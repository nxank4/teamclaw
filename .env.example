# OpenPawl Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# ── Provider API Keys ──────────────────────────────
# Add at least one provider API key

# Anthropic (recommended)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
OPENAI_API_KEY=sk-...

# OpenRouter (access 100+ models)
OPENROUTER_API_KEY=sk-or-...

# DeepSeek (cheap + fast)
DEEPSEEK_API_KEY=sk-...

# Groq (fastest inference)
GROQ_API_KEY=gsk_...

# ── OpenPawl Config ────────────────────────────────
# Dashboard port (default: 8000)
OPENPAWL_PORT=8000

# Workspace path to mount into container
WORKSPACE_PATH=./workspace

# Mock LLM for testing (no API calls)
OPENPAWL_MOCK_LLM=false

# ── Langfuse Observability (optional) ─────────────
# Get free keys at https://cloud.langfuse.com or self-host
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
