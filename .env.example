# TeamClaw Configuration
# Copy to .env and modify as needed

# OpenClaw Gateway (required)
OPENCLAW_WORKER_URL=http://localhost:8001
OPENCLAW_TOKEN=your-openclaw-token

# Optional: LLM request timeout (ms)
# LLM_TIMEOUT_MS=120000

# Optional: orchestration tuning
CREATIVITY=0.5

# Work session limits
MAX_CYCLES=10
MAX_RUNS=5

# Docker only: OpenClaw worker image (required when using `docker compose --profile openclaw up`)
# OPENCLAW_IMAGE=ghcr.io/your-org/openclaw-worker:latest

# Optional: per-bot URLs (JSON)
# OPENCLAW_WORKERS='{"bot_0":"http://localhost:8001","bot_1":"http://localhost:8002"}'

# Optional: provisioning handshake timeout (ms)
# OPENCLAW_PROVISION_TIMEOUT=30000

# Vector Memory backend (no Docker required)
# Options: lancedb | local_json
MEMORY_BACKEND=lancedb
CHROMADB_PERSIST_DIR=data/vector_store
# Optional LanceDB URI (defaults to CHROMADB_PERSIST_DIR/lancedb)
# LANCEDB_URI=data/vector_store/lancedb

# Webhooks (Discord, Slack, Telegram — see docs/WEBHOOKS.md)
# WEBHOOK_ON_TASK_COMPLETE=https://discord.com/api/webhooks/...
# WEBHOOK_ON_CYCLE_END=https://hooks.slack.com/...
# WEBHOOK_SECRET=optional-signature-secret

# Logging
VERBOSE_LOGGING=true
